# --- DATABASE & CORE ---
POSTGRES_USER=de_user
POSTGRES_PASSWORD=de_password
POSTGRES_DB=de_workshop
DATABASE_HOST=localhost
DATABASE_PORT=5432

# --- EXPLORATION & UI ---
JUPYTER_TOKEN=22b90af770b14ca7aeb5615a247e11b4

# --- DOMAIN: PAYMENTS (DEMO 1) ---
API_URL=file:///app/data/payments/transactions.json
CSV_PATH=data/payments/transactions_daily.csv
PARTNER_API_ID=partner_api
PARTNER_CSV_ID=partner_csv
INGEST_SOURCE=both

# --- DOMAIN: IOT (DEMO 2) ---
IOT_INGEST_SOURCE=both
IOT_API_URL=file:///app/data/iot/inbound/telemetry.json
IOT_CSV_PATH=data/iot/inbound/telemetry.csv
IOT_PARTNER_API_ID=iot_api
IOT_PARTNER_CSV_ID=iot_csv

# --- DOMAIN: HR & COMPLIANCE (PII) ---
# No specific env overrides needed for local HR demo defaults

# --- STREAMING & DELTA LAKE (DEMO 3) ---
KAFKA_BOOTSTRAP=iot-kafka:9092
# Chaos Control Rates (0.0 to 1.0)
STREAM_OUTLIER_RATE=0.01
STREAM_BAD_UNIT_RATE=0.005
STREAM_DUPLICATE_RATE=0.01

# --- ORCHESTRATION: AIRFLOW (DEMO 4) ---
AIRFLOW_UID=1000
AIRFLOW_WEBSERVER_PORT=8088
# Connection string for the warehouse (Used by Airflow)
AIRFLOW_CONN_WAREHOUSE=postgresql://de_user:de_password@postgres:5432/de_workshop

